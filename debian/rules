#!/usr/bin/make -f

%:
	dh $@ --with python3 --buildsystem=pybuild

override_dh_auto_test:
	PYTHONPATH=src python3 -m unittest -v \
		tests.test_agent \
		tests.test_core_package \
		tests.test_diagnostics \
		tests.test_join \
		tests.test_orchestrator_identity \
		tests.test_planner \
		tests.test_probe \
		tests.test_readiness \
		tests.test_runtime \
		tests.test_state
